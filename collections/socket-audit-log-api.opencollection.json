{
  "opencollection": "1.0.0",
  "info": {
    "name": "Socket Audit Log API",
    "version": "0"
  },
  "items": [
    {
      "info": {
        "name": "audit-log",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get Audit Log Events",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.socket.dev/v0/orgs/:org_slug/audit-log",
            "params": [
              {
                "name": "org_slug",
                "value": "",
                "type": "path",
                "description": "The slug of the organization"
              },
              {
                "name": "type",
                "value": "",
                "type": "query",
                "description": "Filter audit log events by type. Omit for all types."
              },
              {
                "name": "per_page",
                "value": "",
                "type": "query",
                "description": "Number of events per page"
              },
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "Page token"
              },
              {
                "name": "from",
                "value": "",
                "type": "query",
                "description": "A Unix timestamp in seconds to filter results prior to this date."
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Paginated list of audit log events.\n\nThis endpoint consumes 1 unit of your quota.\n\nThis endpoint requires the following org token scopes:\n- audit-log:list"
        }
      ]
    }
  ],
  "bundled": true
}