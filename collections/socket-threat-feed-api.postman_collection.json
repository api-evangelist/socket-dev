      },
      "item": [
        {
          "id": "86722f5f-6ac7-44b4-97d9-3abe4bc31141",
          "name": "Get Threat Feed Items (Beta)",
          "request": {
            "name": "Get Threat Feed Items (Beta)",
            "description": {
              "content": "Paginated list of threats, sorted by updated_at by default. Set updated_after to the unix timestamp of your last sync while sorting by updated_at to synchronize all new or updated threats in the feed.\n\nThis endpoint requires an Enterprise Plan with Threat Feed add-on. [Contact](https://socket.dev/demo?utm_source=api-docs&utm_medium=referral&utm_campaign=tracking) our sales team for more details.\n\nThis endpoint consumes 1 unit of your quota.\n\nThis endpoint requires the following org token scopes:\n- threat-feed:list",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "orgs",
                ":org_slug",
                "threat-feed"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "per_page",
                  "value": "30",
                  "description": "Number of threats per page"
                },
                {
                  "disabled": false,
                  "key": "page_cursor",
                  "value": "<string>",
                  "description": "Page cursor token. Pass the returned nextPageCursor to this query string to fetch the next page of the threat feed."
                },
                {
                  "disabled": false,
                  "key": "sort",
                  "value": "updated_at",
                  "description": "Set the sort order for the threat feed items. Default is descending order by updated_at, which includes all new and updated threat feed items."
                },
                {
                  "disabled": false,
                  "key": "updated_after",
                  "value": "<string>",
                  "description": "A Unix timestamp in seconds that filters results to items only updated after the timestamp."
                },
                {
                  "disabled": false,
                  "key": "created_after",
                  "value": "<string>",
                  "description": "A Unix timestamp in seconds that filters results to items only created after the date."
                },
                {
                  "disabled": false,
                  "key": "direction",
                  "value": "desc",
                  "description": "Order direction of the provided sort field."
                },
                {
                  "disabled": false,
                  "key": "filter",
                  "value": "mal",
                  "description": "Filter by threat classification. Supported values: `mal` (malware, including possible malware), `vuln` (vulnerability), `typo` (typosquat, including possible typosquat), `anom` (anomaly), `spy` (telemetry), `obf` (obfuscated code), `dual` (dual-use tool), `joke` (protestware or joke package), `tp` (all confirmed true positives), `fp` (false positive), `u` (unreviewed), `c` (classified, i.e. anything except unreviewed)."
                },
                {
                  "disabled": false,
                  "key": "name",
                  "value": "",
                  "description": "Filter threats by package name"
                },
                {
                  "disabled": false,
                  "key": "version",
                  "value": "",
                  "description": "Filter threats by package version."
                },
                {
                  "disabled": false,
                  "key": "is_human_reviewed",
                  "value": "false",
                  "description": "Only return threats which have been human-reviewed"
                },
                {
                  "disabled": false,
                  "key": "ecosystem",
                  "value": "<string>",
                  "description": "Filter threats by package ecosystem."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "org_slug",
                  "description": "(Required) The slug of the organization"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearerToken}}"
                }
              ]
            }
          },
